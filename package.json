{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "last-movies",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:worker-assets": "npm run build && node scripts/generate-worker-assets.mjs",
        "dev": "npm run build && wrangler dev",
        "deploy": "npm run build && wrangler deploy",
        "db:migrate:local": "wrangler d1 migrations apply last-movies --local",
        "db:migrate:remote": "wrangler d1 migrations apply last-movies --remote",
        "test": "vitest run"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7",
        "vitest": "^4.1.5",
        "wrangler": "^4.86.0"
    }
}
